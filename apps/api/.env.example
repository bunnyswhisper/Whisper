# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

FRONTEND_URL=http://localhost:3000

# Resend (transactional email — API only, never expose to web)
RESEND_API_KEY=
EMAIL_FROM_NAME=Bunny's Whisper
EMAIL_FROM_ADDRESS=orders@bunnyswhisper.com

# Paymob Accept (card / intention API)
PAYMOB_SECRET_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_CARD_INTEGRATION_ID=5649958
PAYMOB_CURRENCY=EGP
# Optional overrides
# PAYMOB_API_BASE=https://accept.paymob.com/api
# PAYMOB_API_VERSION=1
# PAYMOB_CHECKOUT_BASE_URL=https://accept.paymob.com/unifiedcheckout/payment
# Full URL Paymob should POST transaction callbacks to (must match dashboard webhook URL)
# PAYMOB_WEBHOOK_URL=https://your-api-host/payments/paymob/webhook
